#!/bin/bash

# Pre-commit hook for static analysis of C++ files
# This hook runs clang-format, clang-tidy, cppcheck, and cpplint on staged C++ files
# Commits will be blocked if any tool finds issues

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any errors were found
ERRORS_FOUND=0

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Get staged C++ files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(cpp|hpp|h|cc|cxx|c\+\+)$' || true)

# If no C++ files are staged, exit successfully
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "Running static analysis on staged C++ files..."
echo ""

# Function to check if a command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Function to report errors
report_error() {
    echo -e "${RED}ERROR:${NC} $1"
    ERRORS_FOUND=1
}

# Function to report warnings
report_warning() {
    echo -e "${YELLOW}WARNING:${NC} $1"
}

# 1. Check clang-format
echo "Checking code formatting with clang-format..."
if ! command_exists clang-format; then
    report_warning "clang-format not found. Skipping format check."
else
    FORMAT_ERRORS=0
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            if ! clang-format --dry-run --Werror "$file" >/dev/null 2>&1; then
                echo -e "${RED}  Formatting error in: $file${NC}"
                echo "  Run: clang-format -i $file"
                FORMAT_ERRORS=1
            fi
        fi
    done
    if [ $FORMAT_ERRORS -eq 1 ]; then
        report_error "clang-format found formatting issues. Please fix them before committing."
    else
        echo -e "${GREEN}  clang-format: OK${NC}"
    fi
fi
echo ""

# 2. Check clang-tidy
echo "Checking code with clang-tidy..."
if ! command_exists clang-tidy; then
    report_warning "clang-tidy not found. Skipping clang-tidy check."
else
    # Check if compile_commands.json exists
    COMPILE_COMMANDS=".build/compile_commands.json"
    if [ ! -f "$COMPILE_COMMANDS" ]; then
        report_warning "compile_commands.json not found at $COMPILE_COMMANDS"
        report_warning "clang-tidy may not work correctly. Run: cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -S . -B .build"
    fi
    
    # Set up clang-tidy arguments
    TIDY_SUPPRESSIONS="assets/clang-tidy-suppressions.yaml"
    TIDY_CONFIG_ARGS=""
    
    if [ -f "$TIDY_SUPPRESSIONS" ]; then
        # Read config file and pass to clang-tidy using --config option
        # Use a here-string to properly handle YAML with newlines and special characters
        TIDY_CONFIG_CONTENT=$(cat "$TIDY_SUPPRESSIONS")
        TIDY_CONFIG_ARGS="--config=$TIDY_CONFIG_CONTENT"
    fi
    
    TIDY_ERRORS=0
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            # Run clang-tidy and capture output
            # clang-tidy options come before the file, compiler flags come after --
            TIDY_OUTPUT=$(clang-tidy $TIDY_CONFIG_ARGS "$file" -- -std=c++17 2>&1 || true)
            if [ -n "$TIDY_OUTPUT" ] && ! echo "$TIDY_OUTPUT" | grep -q "No issues found"; then
                # Filter out warnings about missing compile_commands.json if file doesn't exist
                if [ ! -f "$COMPILE_COMMANDS" ]; then
                    TIDY_OUTPUT=$(echo "$TIDY_OUTPUT" | grep -v "compile_commands.json" || true)
                fi
                if [ -n "$TIDY_OUTPUT" ]; then
                    echo -e "${RED}  Issues found in: $file${NC}"
                    echo "$TIDY_OUTPUT" | sed 's/^/    /'
                    TIDY_ERRORS=1
                fi
            fi
        fi
    done
    if [ $TIDY_ERRORS -eq 1 ]; then
        report_error "clang-tidy found issues. Please fix them before committing."
    else
        echo -e "${GREEN}  clang-tidy: OK${NC}"
    fi
fi
echo ""

# 3. Check cppcheck
echo "Checking code with cppcheck..."
if ! command_exists cppcheck; then
    report_warning "cppcheck not found. Skipping cppcheck check."
else
    CPPCHECK_SUPPRESSIONS="assets/cppcheck-suppressions.txt"
    CPPCHECK_ARGS="--enable=all --std=c++17 --inline-suppr --error-exitcode=1"
    
    if [ -f "$CPPCHECK_SUPPRESSIONS" ]; then
        CPPCHECK_ARGS="$CPPCHECK_ARGS --suppressions-list=$CPPCHECK_SUPPRESSIONS"
    fi
    
    CPPCHECK_ERRORS=0
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            # Run cppcheck and capture output
            CPPCHECK_OUTPUT=$(cppcheck $CPPCHECK_ARGS "$file" 2>&1 || true)
            
            # Check if cppcheck found issues (look for error/warning/style messages)
            # Filter out informational messages like "Checking file.h..."
            if echo "$CPPCHECK_OUTPUT" | grep -vE "^Checking " | grep -qE "(error|warning|style)"; then
                echo -e "${RED}  Issues found in: $file${NC}"
                echo "$CPPCHECK_OUTPUT" | sed 's/^/    /'
                CPPCHECK_ERRORS=1
            fi
        fi
    done
    if [ $CPPCHECK_ERRORS -eq 1 ]; then
        report_error "cppcheck found issues. Please fix them before committing."
    else
        echo -e "${GREEN}  cppcheck: OK${NC}"
    fi
fi
echo ""

# 4. Check cpplint
echo "Checking code with cpplint..."
if ! command_exists cpplint; then
    report_warning "cpplint not found. Skipping cpplint check."
else
    CPPLINT_ERRORS=0
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            # Run cpplint and capture output
            CPPLINT_OUTPUT=$(cpplint "$file" 2>&1 || true)
            if [ -n "$CPPLINT_OUTPUT" ] && ! echo "$CPPLINT_OUTPUT" | grep -q "Total errors found: 0"; then
                echo -e "${RED}  Issues found in: $file${NC}"
                echo "$CPPLINT_OUTPUT" | sed 's/^/    /'
                CPPLINT_ERRORS=1
            fi
        fi
    done
    if [ $CPPLINT_ERRORS -eq 1 ]; then
        report_error "cpplint found issues. Please fix them before committing."
    else
        echo -e "${GREEN}  cpplint: OK${NC}"
    fi
fi
echo ""

# Final result
if [ $ERRORS_FOUND -eq 1 ]; then
    echo -e "${RED}Static analysis failed. Commit blocked.${NC}"
    echo "Please fix the issues above before committing."
    exit 1
else
    echo -e "${GREEN}All static analysis checks passed.${NC}"
    exit 0
fi

